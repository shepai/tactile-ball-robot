<mujoco model="dual_tactile_wheel">

    <option integrator="implicit" timestep="0.01"/>
    <option iterations="50"/>
    <asset>
        <include file="left_wheel/asset.xml"/>
        <include file="right_wheel/asset.xml"/>
        <texture type="2d" name="groundplane" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 .2 .3" width="512" height="512"/>
        <material name="grid" texture="groundplane" reflectance=".2" texrepeat="5 5"/>
    </asset>

    <worldbody>
        <geom name="floor" type="plane" size="0 0 1" pos="0 0 0" material="grid" condim="3" group="1"/>
        
        <camera name="third person" mode="trackcom" target="robot" pos="0.5 0 0.8" fovy="60" euler="0 40 90"/>
        <body name="robot" pos="0 0 0.15">
        <!-- <camera name="third person" mode="track" target="robot" pos="0 -0.5 0.8" fovy="80" euler="40 0 0"/> -->
            <freejoint/>
            
            <inertial
            pos="0 0 0"
            mass="0.8"
            diaginertia="0.01 0.01 0.02"/>
            <geom type="cylinder" size="0.103 0.0025" mass="0.8" quat="0 0 -0.7071 0.7071"/>
            <body name="counterweight">
                <inertial
                    pos="0 0 -0.04"
                    mass="1.8"
                    diaginertia="0.0005 0.0005 0.0005"/>
                <geom contype="0" conaffinity="0"
                    type="box"
                    pos="0 0 -0.04"
                    size="0.02 0.007 0.02"
                    />
            </body>
            <body name="cam_rig" pos="0.102 0 0.03" euler="90 -90 0">

                <camera name="front_cam"
                        pos="0 0 0"
                        euler="0 0 0"
                        fovy="80"/>

                <light name="torch"
                pos="0 0.05 0"
                diffuse="0.8 0.8 0.8" 
                specular="0.2 0.2 0.2"
                directional="true"
                dir="0 -1 -1"
                />
            </body>
            <!-- <camera name="front_cam" pos="0.1 0 0.03" fovy="80" euler="90 -90 0"/>
            <light name="from_cam_light" pos="0.1 0 0.02" dir="0 1 1" diffuse="0.02 0.02 0.02" specular="0.2 0.2 0.2" directional="true" /> -->
            <!-- ======================================================================= -->
            <!-- STABLE HOUSINGS: These hold the cameras and lights so they do NOT rotate -->
            <!-- ======================================================================= -->
            <body name="left_sensor_housing" pos="0 -0.005 0" quat="0 0 -0.7071 0.7071">
                <camera name="sensor_cam_left" pos="0 0 -0.002" fovy="120" zaxis="0 0 -1" />
                <light name="sensor_light_left" pos="0 0 -0.05" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2" directional="true" />
            </body>

            <body name="right_sensor_housing" pos="0 0.005 0" quat="0 0 0.7071 0.7071">
                <camera name="sensor_cam_right" pos="0 0 -0.002" fovy="120" zaxis="0 0 -1" />
                <light name="sensor_light_right" pos="0 0 -0.05" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2" directional="true" />
            </body>

            <!-- ======================================================================= -->
            <!-- ROTATING WHEELS: These bodies handle ONLY the rotation and the mesh     -->
            <!-- ======================================================================= -->
            <body name="left_wheel" pos="0 -0.015 0" quat="0 0 -0.7071 0.7071">
                <joint name="left_joint" type="hinge" axis="0 0 1" damping="0.1"/>
                <inertial pos="0 0 0" mass="0.2" diaginertia="0.001 0.001 0.001"/>
                <include file="left_wheel/worldbody.xml"/>
            </body>
            
            <body name="right_wheel" pos="0 0.015 0" quat="0 0 0.7071 0.7071">
                <joint name="right_joint" type="hinge" axis="0 0 1" damping="0.1"/>
                <inertial pos="0 0 0" mass="0.2" diaginertia="0.001 0.001 0.001"/>
                <include file="right_wheel/worldbody.xml"/>
            </body>

        </body>
    </worldbody>

    <tendon>
        <include file="left_wheel/tendon.xml"/>
        <include file="right_wheel/tendon.xml"/>
    </tendon>
    
    <equality>
        <include file="left_wheel/equality.xml"/>
        <include file="right_wheel/equality.xml"/>
        
    </equality>
    <sensor>
                <jointvel name="left_vel_sensor" joint="left_joint"/>
                <jointvel name="right_vel_sensor" joint="right_joint"/>
    </sensor>
    <actuator>
        <motor name="left_motor" joint="left_joint" gear="1"/>
        <motor name="right_motor" joint="right_joint" gear="1"/>
    </actuator>

      <deformable>
        <!-- <include file="left_wheel/deformable.xml"/>
        <include file="right_wheel/deformable.xml"/> -->
        </deformable>
</mujoco>
