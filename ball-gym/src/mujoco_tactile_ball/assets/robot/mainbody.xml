<mujoco model="dual_tactile_wheel">

    <option integrator="implicit" timestep="0.001"/>
    <option iterations="50"/>
    <asset>
        <include file="left_wheel/asset.xml"/>
        <include file="right_wheel/asset.xml"/>
            <texture name="checker" type="2d" builtin="checker"
             rgb1="0.2 0.3 0.8"  
             rgb2="0.9 0.9 0.9"
             width="300" height="300"/>
            <material name="checker_mat" texture="checker"
              texrepeat="5 5" reflectance="0.1"/>
    </asset>

    <worldbody>

            <geom name="floor"
          type="plane"
          size="5 5 0.1"
          material="checker_mat"/>

        <body name="robot" pos="0 0 0.15">
            <freejoint/>
            <geom type="cylinder" size="0.07 0.001"
                mass="0.05" quat="0 0 -0.7071 0.7071"/>
            
            <body name="left_wheel" pos="0 -0.01 0" quat="0 0 -0.7071 0.7071">

                <joint name="left_joint"
                    type="hinge"
                    axis="0 0 1"/>
                <inertial pos="0 0 0"
                    mass="0.2"
                    diaginertia="0.001 0.001 0.001"/>
                <include file="left_wheel/worldbody.xml"/>

            </body>

            <body name="right_wheel" pos="0 0.01 0" quat="0 0 0.7071 0.7071">

                <joint name="right_joint"
                    type="hinge"
                    axis="0 0 1"/>
                <inertial pos="0 0 0"
                    mass="0.2"
                    diaginertia="0.001 0.001 0.001"/>
                <include file="right_wheel/worldbody.xml"/>

            </body>

        </body>

    </worldbody>
    <tendon>
        <include file="left_wheel/tendon.xml"/>
        <include file="right_wheel/tendon.xml"/>
    </tendon>
    <equality>
            <include file="left_wheel/equality.xml"/>
            <include file="right_wheel/equality.xml"/>
    </equality>
    <actuator>
       <motor name="left_motor"
           joint="left_joint"
           gear="3"/>

        <motor name="right_motor"
            joint="right_joint"
            gear="3"/>
    </actuator>
     <deformable>
            <include file="left_wheel/deformable.xml"/>
            <include file="right_wheel/deformable.xml"/>
    </deformable> 

</mujoco>