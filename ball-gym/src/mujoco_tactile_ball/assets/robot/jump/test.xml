<mujoco model="jumping_ball">
    <option timestep="0.002"
            integrator="implicitfast"
            gravity="0 0 -9.81"
            iterations="50"/>

    <worldbody>

        <!-- Ground -->
        <geom name="ground"
              type="plane"
              size="2 2 0.1"/>

        <!-- Ball -->
        <body name="ball" pos="0 0 0.11">
            <freejoint/>

            <!-- Outer shell -->
            <geom name="shell"
                  type="sphere"
                  size="0.10"
                  mass="1.0"
                  rgba="0.2 0.6 0.8 1"/>

            <!-- Internal sliding mass -->
            <body name="piston">

                <joint name="slider"
                       type="slide"
                       axis="0 0 1"
                       limited="true"
                       range="-0.03 0.03"
                       stiffness="5000"
                       damping="10"/>

                <geom name="mass"
                      type="sphere"
                      size="0.02"
                      mass="0.2"
                      rgba="1 0 0 1"
                      contype="0"
                      conaffinity="0"/>

            </body>

        </body>

    </worldbody>

    <actuator>
        <motor joint="slider"
               gear="300"
               ctrlrange="-1 1"/>
    </actuator>

</mujoco>