<mujoco model="dual_tactile_wheel">

    <option integrator="implicitfast" timestep="0.002"/>
    <option iterations="50"/>
    <asset>
        <include file="robot/asset.xml"/>
        <texture type="2d" name="groundplane" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 .2 .3" width="512" height="512"/>
        <material name="grid" texture="groundplane" reflectance=".2" texrepeat="5 5"/>
         <texture builtin="gradient" height="100" rgb1="1 1 1" rgb2="0 0 0" type="skybox" width="100" />
    <texture builtin="flat" height="1278" mark="cross" markrgb="1 1 1" name="texgeom" random="0.01" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" type="cube" width="127" />
    <texture builtin="checker" height="100" name="texplane" rgb1="0.2 0.4 0.6" rgb2="0.8 0.8 0.8" type="2d" width="100" />
    <material name="MatPlane" reflectance="0.5" shininess="1" specular="1" texrepeat="60 60" texture="texplane" />
    <material name="geom" texture="texgeom" texuniform="true" />
    <hfield file="moss.png" name="mytilted" ncol="0" nrow="0" size="50 50 0.2 0.02" />
    </asset>

    <worldbody>
        <geom conaffinity="1" condim="3" hfield="mytilted" material="MatPlane" name="floor" pos="0 0 0" rgba="0.8 0.9 0.8 1" type="hfield" />
        <camera name="third person" mode="trackcom" target="robot" pos="0.5 0 0.8" fovy="60" euler="0 40 90"/>

        <body name="robot" pos="0 0 0.15">
        <freejoint/>
                <include file="robot/worldbody.xml"/>
        </body>
    </worldbody>

    <tendon>
        <include file="robot/tendon.xml"/>
    </tendon>
    
    <equality>
        <include file="robot/equality.xml"/>
        
    </equality>
    <sensor>
            <include file="robot/sensor.xml"/>
    </sensor>
    <actuator>
        <include file="robot/actuator.xml"/>
    </actuator>

</mujoco>
